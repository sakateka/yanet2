# Dockerfile-specific ignore for dataplane.Dockerfile.
#
# Podman/BuildKit picks this up automatically and it fully replaces the
# root .dockerignore when building with this Dockerfile.

# Git history (not needed for build, saves ~200MB of context).
# Commit hash is passed via --build-arg GIT_COMMIT instead.
.git/

# Host build artifacts.
build/
build-*/
target/
debug/

# Large binary/log files.
*.img
*.qcow2
*.log
*.pcap

# IDE / editor / AI tooling.
.vscode/
.cursor*
.cache/
.cline*
.ai/
.claude/
.assets/

# Rust backup files.
**/*.rs.bk

# Web / Node (not needed for dataplane).
web/node_modules/
web/dist/
web/.vite/

# Fuzzing artifacts.
timeout-*
crash-*
corpus/
default.profdata
default.profraw

# Test VM images.
tests/functional/*.img
tests/functional/*.qcow2

# Debian packaging leftovers.
outdeb/
debian/tmp/

# Misc generated / local-only files.
compile_commands.json
.gdb_history
cscope.*
.envrc
.env
.protolint.yaml
.golangci.yml
go.work
memory-bank/
shell.nix
