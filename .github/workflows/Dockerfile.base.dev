FROM ubuntu:24.04

LABEL maintainer="YANET Team" \
    description="Development environment for YANET2" \
    version="1.0"

ENV DEBIAN_FRONTEND=noninteractive \
    GOCACHE=/tmp/gocache \
    GOMODCACHE=/tmp/gomodcache \
    PATH="/usr/local/go/bin:${PATH}"

ARG GO_VERSION=1.24.13
ARG PROTOC_GEN_GO_VERSION=latest
ARG PROTOC_GEN_GO_GRPC_VERSION=latest

RUN apt-get update -y && apt-get install -y \
    meson \
    clang \
    clang-format-19 \
    clang-tidy-19 \
    curl \
    git \
    just \
    make \
    python3-pyelftools \
    python3-dev \
    libnuma-dev \
    libpcap-dev \
    libyaml-dev \
    protobuf-compiler \
    libprotobuf-dev \
    rustup \
    dpkg-dev \
    debhelper \
    lintian \
    devscripts \
    fakeroot \
    build-essential \
    dh-make \
    equivs \
    pbuilder \
    quilt \
    gdb \
    lldb \
    lcov \
    ca-certificates \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" \
    | tar -C /usr/local -xz

RUN GOBIN=/usr/bin go install google.golang.org/protobuf/cmd/protoc-gen-go@${PROTOC_GEN_GO_VERSION} \
    && GOBIN=/usr/bin go install google.golang.org/grpc/cmd/protoc-gen-go-grpc@${PROTOC_GEN_GO_GRPC_VERSION}

RUN rustup set auto-self-update disable \
    && rustup install stable

RUN mkdir -p /tmp/gocache /tmp/gomodcache \
    && chmod 777 /tmp/gocache /tmp/gomodcache

WORKDIR /yanet2
